# Workers Static Assets does not use zone-level Cache Rules. Keep long browser
# caching limited to fingerprinted assets and published reflection images that
# are never replaced at the same URL.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), geolocation=(), microphone=(), payment=()

/.well-known/security.txt
  Content-Type: text/plain; charset=utf-8

/.well-known/security.asc
  Content-Type: application/pgp-keys

/css/site.*.css
  Cache-Control: public, max-age=31536000, immutable

/js/bible-reading-plan.*.js
  Cache-Control: public, max-age=31536000, immutable

/css/*.woff
  Cache-Control: public, max-age=31536000, immutable

/css/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/css/*.ttf
  Cache-Control: public, max-age=31536000, immutable

/reflections/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/reflections/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

/reflections/*.png
  Cache-Control: public, max-age=31536000, immutable

/reflections/*.webp
  Cache-Control: public, max-age=31536000, immutable
