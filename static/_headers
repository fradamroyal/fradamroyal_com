# Workers Static Assets does not use zone-level Cache Rules. Keep long browser
# caching limited to filenames that change whenever their contents change.

/css/site.*.css
  Cache-Control: public, max-age=31536000, immutable

/js/bible-reading-plan.*.js
  Cache-Control: public, max-age=31536000, immutable

/css/*.woff
  Cache-Control: public, max-age=31536000, immutable

/css/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/css/*.ttf
  Cache-Control: public, max-age=31536000, immutable
